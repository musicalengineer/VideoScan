# Python
venv/
__pycache__/
*.pyc
*.pyo

# Xcode / Swift
build/
.deriveddata/
DerivedData/
*.xcuserstate
xcuserdata/

# macOS
.DS_Store
*.swp

# Generated outputs
*.xlsx
*.csv
*.zip

# Diagnostic / scratch
d.txt
DonnaFaceDetectionTest.png

# Claude Code
.claude/

# ML models (too large for git, downloaded separately)
models/

# Test media — allow small generated fixtures, block large real media
# The pre-commit hook also rejects any staged file > 75 MB
tests/fixtures/videos/*-test-*.mxf
!tests/fixtures/videos/test_*

# Local dashboard cache — populated by scripts/dashboard.sh from
# the `metrics` branch. Never commit; it's a local snapshot.
docs/history.jsonl

# Xcode test result bundles — generated by `xcodebuild ... test
# -resultBundlePath`. Opaque content-addressed blobs, not source.
*.xcresult/

# Build / lint / CI scratch output — all regeneratable
/xcodebuild-test.log
/periphery-raw.txt
/swiftlint-raw.txt
/docs/metrics-report.html

# Generated face-recognition outputs (embeddings, scan CSVs, plots)
/output/

# POI data now lives in ~/Library/Application Support/VideoScan/POI/
# (issue #35). Any lingering legacy copies in the repo are local state.
/poi_profiles/
/poi_photos/

# Personal / scratch files that end up in the repo root
/ricksnotes.txt
/recover_timmy.mov
